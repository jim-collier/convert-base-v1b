	((doQuietly))  &&  return
	#           X"-------------------------------------------------------------------------------"X
	fEcho_Clean ""
	fEcho_Clean "Syntax: ${meName}  [optional args]  <NUMBER>  <OBASE>"
	fEcho_Clean "  Required arguments (in any order):"
